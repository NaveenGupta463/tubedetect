# YouTube Data API v3 key (server-side only — never exposed to browser)
YT_API_KEY=your_youtube_data_api_v3_key_here

# Anthropic API key (server-side only)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT signing secret — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_string_in_production

# Port — Cloud Run injects PORT=8080 automatically; leave unset in production
PORT=8080

# Comma-separated list of allowed frontend origins
# Local dev:   http://localhost:5173
# Production:  https://your-app.web.app,https://your-custom-domain.com
CORS_ORIGIN=http://localhost:5173

# Optional: directory for db.json (mount a Cloud Run volume here for persistence)
# Leave unset to use the default location (ephemeral — fine for dev/testing)
# DATA_DIR=/mnt/data
